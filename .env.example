# Convex deployment URL (required)
# Get this from your Convex dashboard: https://dashboard.convex.dev
EXPO_PUBLIC_CONVEX_URL=

# WorkOS AuthKit client ID (required)
# Get this from your WorkOS dashboard: https://dashboard.workos.com
EXPO_PUBLIC_WORKOS_CLIENT_ID=

# OAuth redirect URI (optional, defaults to 'rondas://callback')
# Override if using a custom deep link scheme
EXPO_PUBLIC_REDIRECT_URI=

# Google Places API key (optional, used for venue/location lookup)
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=

# Server-side secrets go into Convex environment variables (not here)
# Use: pnpm dlx convex env set KEY value
